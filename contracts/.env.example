# Deployer wallet (needs Sepolia ETH for gas)
DEPLOYER_PRIVATE_KEY=0xYOUR_PRIVATE_KEY

# Sepolia RPC
RPC_URL=https://sepolia.infura.io/v3/YOUR_KEY

# Optional: separate guardian address for pause role (defaults to deployer)
# GUARDIAN_ADDRESS=0x...

# Optional: separate attacker key for Simulate script (defaults to deployer)
# ATTACKER_PRIVATE_KEY=0x...
