# 0G Testnet (chain 16602)
RPC_URL=https://evmrpc-testnet.0g.ai
DEPLOYER_PRIVATE_KEY=0xYOUR_PRIVATE_KEY

# Deployed contract addresses (0G testnet)
MOCK_BRIDGE_ADDRESS=0xD2efb57cFA2a7626d520C45a8304AD3162FE32Af
FAKE_RSETH_ADDRESS=0x2b54FeC881C9230A2740Bef0E1d91E50Eb483ca1
MOCK_WETH_ADDRESS=0x7740B82991d0c659A370EF82a4910E0e914C4253
MOCK_LENDING_ADDRESS=0xD46bBD0362b1F8feb764366805F98f8782Ab81DA

# Frontend (Next.js public env vars)
NEXT_PUBLIC_LENDING_ADDRESS=       # same as MOCK_LENDING_ADDRESS, for the dashboard Pause button
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=  # get one free at https://cloud.walletconnect.com
NEXT_PUBLIC_RISK_AGENT_URL=http://localhost:4000  # dashboard polls this for live signals

# ENS (Sepolia)
ENS_NAME=bridgesentinel.eth
SEPOLIA_RPC_URL=https://rpc.sepolia.org

# Gensyn AXL
USE_AXL=false
# Per-agent AXL sidecar HTTP API ports (each agent talks to its own sidecar)
AXL_API_PORT=9002              # Config Agent sidecar
AXL_ANOMALY_API_PORT=9012      # Anomaly Agent sidecar
AXL_RISK_API_PORT=9022         # Risk Agent sidecar
# Peer pubkeys (filled after AXL nodes start — get from GET /topology)
AXL_CONFIG_PUBKEY=
AXL_ANOMALY_PUBKEY=
AXL_RISK_PUBKEY=

# Agent HTTP ports (local transport)
CONFIG_AGENT_PORT=4001
ANOMALY_AGENT_PORT=4002
RISK_AGENT_PORT=4000
RISK_AGENT_URL=http://localhost:4000/signal

# Agent thresholds (anomaly agent)
DEPOSIT_SUPPLY_PCT=30
LTV_THRESHOLD_PCT=70
POLL_INTERVAL_MS=15000

# 0G Compute
ZG_PRIVATE_KEY=0xYOUR_0G_WALLET_PRIVATE_KEY
ZG_RPC_URL=https://evmrpc-testnet.0g.ai
ZG_PROVIDER_ADDRESS=
ZG_MODEL=qwen-2.5-7b-instruct
