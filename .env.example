# Sepolia
SEPOLIA_RPC_URL=https://sepolia.infura.io/v3/YOUR_KEY
DEPLOYER_PRIVATE_KEY=0xYOUR_PRIVATE_KEY

# Deployed contract addresses (filled after BearPrince deploys)
MOCK_BRIDGE_ADDRESS=
FAKE_RSETH_ADDRESS=
MOCK_LENDING_ADDRESS=

# Frontend (Next.js public env vars)
NEXT_PUBLIC_LENDING_ADDRESS=       # same as MOCK_LENDING_ADDRESS, for the dashboard Pause button
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=  # get one free at https://cloud.walletconnect.com

# ENS
ENS_NAME=bridgesentinel.eth

# Gensyn AXL (per-agent, override in each agent's .env)
AXL_API_PORT=9002
AXL_TCP_PORT=9001
AXL_PRIVATE_KEY_PATH=./axl/private.pem
# Peer pubkeys (filled after AXL nodes start — get from GET /topology)
AXL_CONFIG_PUBKEY=
AXL_ANOMALY_PUBKEY=
AXL_RISK_PUBKEY=

# 0G Compute
ZG_PRIVATE_KEY=0xYOUR_0G_WALLET_PRIVATE_KEY
ZG_RPC_URL=https://evmrpc-testnet.0g.ai
ZG_PROVIDER_ADDRESS=
ZG_MODEL=qwen-2.5-7b-instruct
